---
interface Props {
  variant?: 'color' | 'mono';
  class?: string;
}
const { variant = 'color', class: className } = Astro.props;
---

<svg
  class={`mark mark--${variant} ${className ?? ''}`}
  viewBox="0 0 120 70"
  width="32"
  height="19"
  aria-hidden="true"
  focusable="false"
>
  <circle class="mark__circle" cx="60" cy="16" r="11" />
  <path
    class="mark__wave"
    d="M14 44 C 26 36, 38 36, 50 42 C 62 48, 74 48, 86 40 C 92 36, 100 34, 106 36"
    stroke-width="9"
    stroke-linecap="round"
    fill="none"
  />
</svg>

<style>
  .mark--color .mark__circle {
    fill: var(--color-accent);
  }

  .mark--color .mark__wave {
    stroke: var(--color-primary);
  }

  .mark--mono .mark__circle {
    fill: currentColor;
  }

  .mark--mono .mark__wave {
    stroke: currentColor;
  }
</style>
