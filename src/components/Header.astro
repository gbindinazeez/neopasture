---
import Logo from './Logo.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="header">
  <Logo />
  <nav class="header__nav" aria-label="Primary">
    <a class="header__link" href={`${base}/how-it-works`}>How it works</a>
    <a class="header__cta" href={`${base}/join`}>Join the waitlist</a>
  </nav>
</header>

<style>
  .header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-5) var(--page-margin);
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .header__nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-5);
  }

  .header__link,
  .header__cta {
    font-size: var(--font-small);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: var(--space-1);
  }

  .header__cta {
    border-bottom-color: var(--color-rule);
  }

  .header__link:hover,
  .header__cta:hover {
    border-bottom-color: var(--color-primary);
  }
</style>
