---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="hero">
  <h1>Your digital lasso for livestock care.</h1>
  <p class="hero__description">
    NeoPasture is in development for individuals and small farmers who want livestock without the
    time, grazing land, or know-how it usually takes.
  </p>
  <a class="hero__cta" href={`${base}/join`}>Join the waitlist</a>
</section>

<style>
  .hero {
    padding: var(--space-8) var(--page-margin) var(--space-7);
    max-width: var(--page-width);
    margin: 0 auto;
    border-bottom: 1px solid var(--color-rule);
  }

  .hero h1 {
    font-size: var(--font-display);
    max-width: 20ch;
  }

  .hero__description {
    margin-top: var(--space-5);
    font-size: var(--font-h3);
    color: var(--color-ink-muted);
  }

  .hero__cta {
    display: inline-block;
    margin-top: var(--space-6);
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-sm);
    background: var(--color-primary);
    color: var(--color-canvas);
    font-weight: 600;
    text-decoration: none;
    transition: background var(--motion-fast) var(--ease-standard);
  }

  .hero__cta:hover {
    background: var(--color-ink);
    color: var(--color-canvas);
  }
</style>
